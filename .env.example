# nats-horizon configuration
# Copy this file to .env and adjust values as needed

# === Smart Port Selection ===
# PORT=3000                    # Preferred port (default: 3000)
# AUTO_PORT=true               # Auto-find free port if busy (default: true)
# PORT_RANGE_START=3001        # Sequential sweep starts here (default: 3001)
# PORT_RANGE_END=3020          # Sequential sweep ends here (default: 3020)
#
# How it works:
#   1. Tries PORT (default 3000) first
#   2. If busy, sweeps PORT_RANGE_START to PORT_RANGE_END sequentially
#   3. If still busy, picks a random port from the range
#   4. Logs the actual port so you know where to open the browser
#
# To disable auto-port and fail if the port is busy:
#   AUTO_PORT=false PORT=3000

# === Server ===
PORT=3000
GIN_MODE=release

# === NATS Connection ===
# For Docker Compose (internal network), use: nats://nats:4222
# For external NATS, use the actual host address
NATS_URL=nats://nats:4222

# === CORS ===
# CORS_ALLOWED_ORIGINS=*

# === Pagination ===
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# === Email (SMTP) ===
# Configure SMTP for email alerts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=nats-horizon@example.com
